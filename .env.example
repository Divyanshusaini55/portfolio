# GitHub Pages Deployment Configuration
# Copy this file to .env.local and update values for your environment
# .env.local is NEVER committed to git (see .gitignore)

# ==============================================================================
# DOMAIN CONFIGURATION (Required for proper deployment)
# ==============================================================================

# For GitHub Pages default (recommended):
# NEXT_PUBLIC_DOMAIN=https://divyanshu-portfolio.pages.github.io

# For custom domain:
# NEXT_PUBLIC_DOMAIN=https://yourdomain.com

# This is used in:
# - Open Graph meta tags (social media sharing)
# - Twitter Card meta tags
# - Canonical URL
# - robots.txt sitemap reference
NEXT_PUBLIC_DOMAIN=https://divyanshu-portfolio.pages.github.io

# Site name for metadata
NEXT_PUBLIC_SITE_NAME=Divyanshu Saini Portfolio

# ==============================================================================
# SOCIAL MEDIA CONFIGURATION (Used in components)
# ==============================================================================

NEXT_PUBLIC_TWITTER_HANDLE=dvyanshux
NEXT_PUBLIC_GITHUB_USERNAME=Divyanshusaini55
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/divyanshu47

# ==============================================================================
# CONTACT INFORMATION (Optional - Used in contact form)
# ==============================================================================

# Email for contact form (if implemented)
# NEXT_PUBLIC_CONTACT_EMAIL=your.email@example.com

# ==============================================================================
# ANALYTICS (Optional)
# ==============================================================================

# Vercel Analytics (already integrated, no key needed)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=optional_if_using_self_hosted

# ==============================================================================
# IMPORTANT NOTES
# ==============================================================================

# 1. Prefix "NEXT_PUBLIC_" means variable is accessible in browser
#    - Use only for NON-SENSITIVE data (domain, usernames, handles)
#    - NEVER use for API keys, passwords, or secrets

# 2. Variables without "NEXT_PUBLIC_" are build-time only
#    - Server-side only (not accessible in browser)
#    - Still not secret if in .env (use .env.local instead)

# 3. GitHub Secrets for CI/CD
#    - Set NEXT_PUBLIC_DOMAIN via GitHub Actions secret
#    - Used during workflow build for dynamic domain support
#    - Go to: Settings → Secrets and variables → Actions

# 4. Environment files hierarchy (in order of priority):
#    .env.local                  (local overrides, not committed)
#    .env.development.local      (development only)
#    .env.production.local       (production only)
#    .env.local                  (fallback)
#    .env                        (version controlled defaults)
#    .env.example               (this file - documentation)

# 5. Hot reload
#    Changes to .env.local require restart: npm run dev

NEXT_PUBLIC_EMAIL=divyanshusai47@email.com
NEXT_PUBLIC_PHONE=+91 9193005455

# Optional: Analytics
NEXT_PUBLIC_GA_ID=

# Optional: Email Service
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
